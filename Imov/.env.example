# Copie para .env e preencha. O .env NAO deve ser versionado.

# Banco de dados
MYSQL_ROOT_PASSWORD=troque-esta-senha
DB_USERNAME=root
DB_PASSWORD=troque-esta-senha

# JWT (gere um segredo forte, >= 256 bits). Ex.: openssl rand -base64 48
JWT_SECRET=gere-um-segredo-forte-aqui
JWT_EXPIRATION=604800000

# E-mail (conta de envio - use uma senha de app)
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
